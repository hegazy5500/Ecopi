# App
NEXT_PUBLIC_APP_NAME=RecycleVerse Pi
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# Security
JWT_SECRET=change-me-super-secret

# Pi Platform
NEXT_PUBLIC_PI_SANDBOX=true
NEXT_PUBLIC_PI_SDK_URL=https://sdk.minepi.com/pi-sdk.js
PI_API_KEY=your_pi_api_key
PI_WALLET_ADDRESS=your_pi_wallet_address
PI_SERVER_BASE_URL=https://api.minepi.com

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token
NEXT_PUBLIC_MAP_DEFAULT_LAT=30.0444
NEXT_PUBLIC_MAP_DEFAULT_LNG=31.2357

# AI Providers
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# Marketplace / NFT assets
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/
NFT_STORAGE_API_KEY=
